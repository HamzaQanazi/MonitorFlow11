# Per-deployment branding for the web console. Copy to `web/.env` and edit, or
# set these in the build environment — either way they are read at BUILD time,
# so rebranding means rebuilding (CLAUDE.md §13: one organisation per
# deployment). Defaults live in src/brand.ts; unset falls back to those.
#
# Not secrets — the values ship inside the built bundle. `.env` is gitignored
# repo-wide, which is why this example file exists.

# Company name. Both languages, because every user-facing label is bilingual (I5).
VITE_BRAND_NAME_EN=MonitorFlow
VITE_BRAND_NAME_AR=مونيتر فلو

# Optional logo, as a path under web/public (e.g. /logo.svg). Leave unset to
# keep the shipped look, which draws a small accent pip instead.
# VITE_BRAND_LOGO=/logo.svg
